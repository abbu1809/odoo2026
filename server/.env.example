DATABASE_URL="postgresql://postgres:postgres@localhost:5432/transitops?schema=public"

PORT=4000
NODE_ENV=development

JWT_SECRET="change-this-dev-secret-before-deploying"
JWT_EXPIRES_IN="1d"

CORS_ORIGIN="http://localhost:5173"

# Optional: SMTP for welcome emails + license-expiry reminders (Todo.md).
# If SMTP_HOST is unset, emails are skipped and just logged to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="TransitOps <no-reply@transitops.io>"

# Optional: where uploaded vehicle documents are stored (Todo.md).
UPLOADS_DIR=uploads
