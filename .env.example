# Copy to .env to override the docker-compose defaults.
# docker-compose reads this file automatically (same directory as docker-compose.yml).

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=transitops

JWT_SECRET=change-this-dev-secret-before-deploying
JWT_EXPIRES_IN=1d

# Origin allowed to call the API (must match wherever the client container is published).
CORS_ORIGIN=http://localhost:5173

# Baked into the client bundle at build time — must be reachable from the
# *browser*, not just from inside the Docker network.
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Host ports (change if one is already taken on your machine).
DB_PORT=5432
SERVER_PORT=4000
CLIENT_PORT=5173

# Re-run the idempotent demo-data seed on every container start. Set to
# "false" once you don't want the demo accounts/vehicles recreated.
SEED_ON_START=true
